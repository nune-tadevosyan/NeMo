#!/usr/bin/env python3
"""Run Canary ASR on a manifest by calling the model's `transcribe` API directly."""

import argparse
import json
import os
from typing import Iterable, List, Tuple

import torch

from nemo.collections.asr.models import ASRModel
from nemo.collections.common.parts.preprocessing.manifest import get_full_path

from nemo.collections.asr.parts.utils.rnnt_utils import Hypothesis
from nemo.collections.asr.parts.utils.transcribe_utils import get_inference_device

DEFAULT_MODEL_NAME = "nvidia/canary-1b-v2"
DEFAULT_MANIFEST = os.path.expanduser(
    "/home/ntadevosyan/data/TAL/correct_2.json"
)


def _load_manifest(manifest_path: str, audio_key: str, limit: int | None = None) -> Tuple[List[str], List[dict]]:
    """Read the manifest and collect absolute audio paths."""
    filepaths: List[str] = []
    entries: List[dict] = []

    with open(manifest_path, "r", encoding="utf-8") as manifest_file:
        for line_number, raw_line in enumerate(manifest_file, start=1):
            if limit is not None and len(filepaths) >= limit:
                break

            line = raw_line.strip()
            if not line:
                continue

            item = json.loads(line)
            if audio_key not in item:
                raise KeyError(f"Missing '{audio_key}' key on line {line_number} of manifest {manifest_path}")

            absolute_path = get_full_path(audio_file=item[audio_key], manifest_file=manifest_path)
            filepaths.append(absolute_path)
            item[audio_key] = absolute_path
            entries.append(item)

    if not filepaths:
        raise ValueError(f"Found no audio entries in manifest {manifest_path}")
    return filepaths, entries


def _serialize_hypothesis(hypothesis: str | Hypothesis) -> dict:
    """Convert raw decoder output into a JSON-serialisable dict."""
    if isinstance(hypothesis, Hypothesis):
        data = {"text": hypothesis.text}
        if hypothesis.timestamp:
            data["timestamp"] = hypothesis.timestamp
        if hypothesis.word_confidence is not None:
            data["word_confidence"] = hypothesis.word_confidence
        if hypothesis.frame_confidence is not None:
            data["frame_confidence"] = hypothesis.frame_confidence
        return data

    return {"text": hypothesis}


def _write_output(records: Iterable[dict], output_path: str) -> None:
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    with open(output_path, "w", encoding="utf-8") as outfile:
        for record in records:
            outfile.write(json.dumps(record, ensure_ascii=False) + "\n")


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Transcribe audio listed in a manifest using Canary's pretrained NeMo model."
    )
    parser.add_argument(
        "--manifest",
        default=DEFAULT_MANIFEST,
        help="Path to the NeMo-style JSON manifest containing an 'audio_filepath' per line.",
    )
    parser.add_argument(
        "--pretrained-name",
        default=DEFAULT_MODEL_NAME,
        help="Name of the pretrained model to download/load via NeMo's ASRModel.from_pretrained.",
    )
    parser.add_argument(
        "--audio-key",
        default="audio_filepath",
        help="Manifest key that stores the audio path. Defaults to 'audio_filepath'.",
    )
    parser.add_argument(
        "--output",
        default=None,
        help="Optional path to write JSONL transcriptions. Prints to stdout when omitted.",
    )
    parser.add_argument("--limit", type=int, default=None, help="Optional maximum number of manifest entries to run.")
    parser.add_argument("--batch-size", type=int, default=1, help="Batch size supplied to model.transcribe.")
    parser.add_argument("--num-workers", type=int, default=0, help="DataLoader workers used in transcription.")
    parser.add_argument(
        "--channel-selector",
        default=None,
        help="Select channels for multi-channel audio (int, comma separated list, or 'average').",
    )
    parser.add_argument(
        "--cuda",
        type=int,
        default=None,
        help="CUDA device index. Leave unset for auto-detection. Use negative value to force CPU.",
    )
    parser.add_argument(
        "--allow-mps",
        action="store_true",
        help="Allow running on Apple MPS device when CUDA is unavailable (requires macOS).",
    )
    parser.add_argument(
        "--matmul-precision",
        default="high",
        choices=["highest", "high", "medium"],
        help="Precision passed to torch.set_float32_matmul_precision.",
    )
    parser.add_argument(
        "--no-timestamps",
        dest="timestamps",
        action="store_false",
        help="Skip requesting timestamp information from the decoder.",
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="Disable progress output from NeMo during inference.",
    )

    parser.set_defaults(timestamps=True)
    return parser.parse_args()


def main() -> None:
    args = _parse_args()

    manifest_path = os.path.expanduser(args.manifest)
    if not os.path.exists(manifest_path):
        raise FileNotFoundError(f"Manifest not found: {manifest_path}")

    audio_paths, manifest_entries = _load_manifest(manifest_path, audio_key=args.audio_key, limit=args.limit)

    torch.set_float32_matmul_precision(args.matmul_precision)
    device = 'cuda'

    model = ASRModel.from_pretrained(model_name=args.pretrained_name, map_location=device)
    model.to(device)
    model.eval()
    with torch.no_grad():
        hypotheses = model.transcribe(
            audio=audio_paths,
            batch_size=1,
            num_workers=args.num_workers,
            channel_selector=args.channel_selector,
            timestamps=False,
            verbose=not args.quiet,
        )

    records = []
    for entry, hypothesis in zip(manifest_entries, hypotheses):
        payload = {"audio_filepath": entry[args.audio_key]}
        payload.update(_serialize_hypothesis(hypothesis))
        if "text" in entry:
            payload["reference_text"] = entry["text"]
        records.append(payload)

    output_path = "./test.jsonl"
    _write_output(records, output_path)


if __name__ == "__main__":
    main()

